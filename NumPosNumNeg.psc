//Problema
//Un programa que solicite al usuario un valor numerico
//Mostrar en pantalla si positivo o negativo
Algoritmo NumPosNumeg
	//Variable
	Definir num Como Entero
	Escribir "Dame un numero entero: "
	Leer  num
	
	//Condición
	Si num >= 0 Entonces
		Escribir "Soy un numero POSITIVO"
	SiNo
		Escribir "Soy un numero NEGATIVO"
	Fin Si
FinAlgoritmo
